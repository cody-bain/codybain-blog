---
import type { Workout } from '../utils/parseMetcons';

interface Props {
  workout: Workout;
  postScore?: string;
}

const { workout, postScore } = Astro.props;
---
<div class="metcon-card">
  <div class="metcon-card__header">
    <a href={`/workouts/${workout.slug}`} class="metcon-card__name">{workout.name}</a>
    {postScore && <span class="metcon-card__score">{postScore}</span>}
  </div>

  <div class="metcon-card__meta">
    {workout.type && <span class="tag">{workout.type}</span>}
    {workout.movements.map(m => <span class="tag">{m}</span>)}
    {workout.equipment.map(e => <span class="tag tag--equipment">{e}</span>)}
  </div>
</div>

<style>
  .metcon-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    margin: 1rem 0;
  }

  .metcon-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .metcon-card__name {
    font-weight: 600;
    color: var(--accent);
    font-size: 1.05rem;
    text-decoration: none;
  }

  .metcon-card__name:hover {
    text-decoration: underline;
  }

  .metcon-card__score {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent);
    background: rgba(232, 197, 71, 0.1);
    padding: 0.2em 0.6em;
    border-radius: 3px;
  }

  .metcon-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag--equipment {
    opacity: 0.7;
  }
</style>
