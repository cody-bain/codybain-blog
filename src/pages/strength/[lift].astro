---
import Base from '../../layouts/Base.astro';
import StrengthDashboard from '../../components/StrengthDashboard';
import { buildStrengthDb, slugToLift } from '../../utils/parseStrength';

export async function getStaticPaths() {
  const db = await buildStrengthDb();
  return db.map(liftData => ({
    params: { lift: liftData.slug },
    props: { liftData },
  }));
}

const { liftData } = Astro.props;
const { lift, slug, sessions } = liftData;
---
<Base title={lift}>

  <div style="margin-bottom:2rem;">
    <a href="/training#strength" style="font-size:0.85rem; color:var(--text-muted);">← Strength</a>
  </div>

  <div style="margin-bottom:2rem;">
    <h1 style="font-size:1.75rem; font-weight:600;">{lift}</h1>
  </div>

  <StrengthDashboard
    client:load
    sessions={sessions}
    lift={lift}
    slug={slug}
  />

</Base>
